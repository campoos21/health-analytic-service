# Django
# A long, random, unique secret key used for cryptographic signing.
DJANGO_SECRET_KEY=your-secret-key-here
# Set to 1 to enable debug mode (never enable in production).
DJANGO_DEBUG=0
# Comma-separated list of allowed hostnames.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
# Name of the PostgreSQL database.
POSTGRES_DB=health_analytic_db
# PostgreSQL user.
POSTGRES_USER=health_user
# PostgreSQL password — change to a strong value in production.
POSTGRES_PASSWORD=change-me
# Hostname of the database service (matches the docker-compose service name).
POSTGRES_HOST=db
# PostgreSQL port.
POSTGRES_PORT=5432

# Django Superuser (created automatically on first start)
# Username for the auto-created Django admin account.
DJANGO_SUPERUSER_USERNAME=admin
# Email for the auto-created Django admin account.
DJANGO_SUPERUSER_EMAIL=admin@example.com
# Password for the auto-created Django admin account — change in production.
DJANGO_SUPERUSER_PASSWORD=change-me

# CORS
# Comma-separated list of allowed origins for cross-origin requests.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
# Log level for the root logger (DEBUG, INFO, WARNING, ERROR, CRITICAL).
DJANGO_LOG_LEVEL=INFO

# Database connection
# Persistent connection lifetime in seconds (0 = close after each request).
DB_CONN_MAX_AGE=600
